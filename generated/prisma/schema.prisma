generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoHabitacion {
  DISPONIBLE
  MANTENIMIENTO
  INACTIVA
}

enum EstadoReserva {
  PENDIENTE_PAGO
  CONFIRMADA
  CANCELADA
  EXPIRADA
  CHECK_IN
  CHECK_OUT
}

enum EstadoPago {
  NO_GENERADO
  PENDIENTE
  APROBADO
  RECHAZADO
  VENCIDO
  REEMBOLSADO
}

enum ConversationMode {
  BOT
  HUMANO
}

enum BookingStep {
  INICIO
  PIDIENDO_FECHAS
  PIDIENDO_PERSONAS
  MOSTRANDO_DISPONIBILIDAD
  ESPERANDO_CONFIRMACION
  ESPERANDO_PAGO
  COMPLETADO
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL
}

model Habitacion {
  id        String           @id @default(uuid())
  numero    String           @unique
  capacidad Int
  estado    EstadoHabitacion @default(DISPONIBLE)
  activa    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  reservas Reserva[]

  @@map("habitaciones")
}

model Cliente {
  id        String   @id @default(uuid())
  nombre    String
  telefono  String   @unique
  correo    String?
  documento String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservas Reserva[]

  @@map("clientes")
}

model Tarifa {
  id        String   @id @default(uuid())
  personas  Int      @unique
  precio    Decimal  @db.Decimal(10, 2)
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tarifas")
}

model Reserva {
  id           String @id @default(uuid())
  codigo       String @unique
  clienteId    String
  habitacionId String

  fechaEntrada DateTime
  fechaSalida  DateTime

  cantidadPersonas Int
  cantidadNoches   Int

  precioPorNoche Decimal @db.Decimal(10, 2)
  precioTotal    Decimal @db.Decimal(10, 2)

  estado EstadoReserva @default(PENDIENTE_PAGO)

  expiraEn DateTime?

  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente    Cliente    @relation(fields: [clienteId], references: [id])
  habitacion Habitacion @relation(fields: [habitacionId], references: [id])
  pago       Pago?

  @@index([fechaEntrada, fechaSalida])
  @@index([habitacionId, estado])
  @@index([clienteId])
  @@map("reservas")
}

model Pago {
  id        String @id @default(uuid())
  reservaId String @unique

  proveedor         String  @default("CLINPAYS")
  referenciaExterna String? @unique

  monto  Decimal @db.Decimal(10, 2)
  moneda String  @default("HNL")

  estado EstadoPago @default(NO_GENERADO)

  urlPago String?

  fechaPago DateTime?

  respuestaProveedor Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reserva Reserva @relation(fields: [reservaId], references: [id])

  @@map("pagos")
}

model ImagenHabitacion {
  id          String   @id @default(uuid())
  url         String
  descripcion String?
  orden       Int      @default(0)
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("imagenes_habitacion")
}

model Conversation {
  id String @id @default(uuid())

  telefono String @unique

  mode ConversationMode @default(BOT)
  step BookingStep      @default(INICIO)

  nombreCliente    String?
  fechaEntrada     DateTime?
  fechaSalida      DateTime?
  cantidadPersonas Int?

  reservaId String?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  ultimaDisponibilidadAt DateTime?
  reservaIds             Json?

  messages Message[]

  @@map("conversations")
}

model Message {
  id String @id @default(uuid())

  conversationId String

  role MessageRole

  content String

  toolName String?

  toolData Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
