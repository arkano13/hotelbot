# Base PostgreSQL EXCLUSIVA para pruebas. El nombre debe contener "test".
TEST_DATABASE_URL=postgresql://usuario:clave@localhost:5432/hotelbot_test

# La integración no borra datos si este valor no es exactamente SI.
ALLOW_TEST_DATABASE_RESET=SI

# Variables usadas por las pruebas HTTP sin conectar WhatsApp.
API_KEY=hotelbot-test-key
GEMINI_API_KEY=clave-de-prueba
OWNER_PHONE=50499999999
MAX_AUDIO_SECONDS=180
